{
  "manifest_version": 3,
  "name": "Claude Maxer",
  "version": "1.0.0",
  "description": "Automatically triggers your Claude usage window reset and shows real-time session usage on claude.ai.",
  "permissions": ["alarms", "tabs", "storage", "scripting", "notifications"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icon48.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected/bridge.js", "src/styles/bar.css"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "icons": {
    "16": "assets/icon48.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
